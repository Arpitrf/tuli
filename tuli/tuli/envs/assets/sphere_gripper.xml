<?xml version="1.0" encoding="UTF-8"?>
<mujoco model="sphere_hand">
    <worldbody>
        <body name="sphere_gripper" pos="0 0 0.015" quat="0.707107 0 0 -0.707107">
            <!-- Force/Torque sensor frame site -->
            <site name="ft_frame" pos="0 0 0" size="0.01 0.01 0.01" rgba="1 0 0 1" type="sphere" group="1"/>
            <inertial pos="0 0 0" mass="3e-2" diaginertia="1e-2 1e-2 1e-2"/>

            <!-- Main sphere -->
            <geom type="sphere" pos="0 0 0" size="0.02" name="sphere_visual" contype="0" conaffinity="0" group="1" rgba="0.3 0.3 0.8 0.6"/>
            <!-- <geom type="sphere" pos="0 0 0" size="0.021" name="sphere_collision" group="0" solimp="0.2 0.9 0.01" solref="0.05 1" solmix="10000" rgba="0.8 0.3 0.3 0.3" friction="0.001 0.005 0.0001"/> -->
            <geom type="sphere" pos="0 0 0" size="0.021" name="sphere_collision" group="0" solimp="0.0 0.9 0.02" solref="0.05 1" solmix="10000" rgba="0.8 0.3 0.3 0.3" friction="0.4 0.005 0.0001"/>

            <!-- Contact detection geom at the bottom of the sphere -->
            <geom type="sphere" pos="0 0 -0.02" size="0.001" name="sphere_contact" group="0" rgba="0 1 0 0.3" solimp="0.0 0.1 0.01" solmix="10000" solref="1 2" friction="0.001 0.005 0.0001"/>
            <!-- Site for touch sensor -->
            <site type="sphere" pos="0 0 -0.02" size="0.001" name="sphere_contact_site"/>

            <!-- End effector frame -->
            <body name="eef" pos="0 0 0" quat="1 0 0 0">
                <site name="grip_site" pos="0 0 0" size="0.01 0.01 0.01" rgba="1 0 0 0.5" type="sphere" group="1"/>
                <site name="ee_x" pos="0.1 0 0" size="0.005 .1" quat="0.707105 0 0.707108 0" rgba="1 0 0 0" type="cylinder" group="1"/>
                <site name="ee_y" pos="0 0.1 0" size="0.005 .1" quat="0.707105 0.707108 0 0" rgba="0 1 0 0" type="cylinder" group="1"/>
                <site name="ee_z" pos="0 0 0.1" size="0.005 .1" quat="1 0 0 0" rgba="0 0 1 0" type="cylinder" group="1"/>
                <site name="grip_site_cylinder" pos="0 0 0" size="0.005 10" rgba="0 1 0 0.3" type="cylinder" group="1"/>
            </body>
        </body>
    </worldbody>
    <sensor>
        <force name="force_ee" site="ft_frame"/>
        <torque name="torque_ee" site="ft_frame"/>
        <touch name="touch" site="sphere_contact_site"/>
    </sensor>
</mujoco>